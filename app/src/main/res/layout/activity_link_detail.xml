<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/holo_blue_dark"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- URL Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="URL"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/darker_gray"
                android:layout_marginBottom="5dp" />

            <TextView
                android:id="@+id/tv_full_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="https://example.com"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"
                android:textIsSelectable="true"
                android:padding="8dp"
                android:background="@color/lighter_gray" />

            <!-- Host -->
            <TextView
                android:id="@+id/tv_host"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Host: example.com"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <!-- Verdict Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:padding="12dp"
                android:background="@color/lighter_gray">

                <ImageView
                    android:id="@+id/iv_verdict_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_check_circle"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tv_verdict"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SAFE"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/holo_green_dark" />

            </LinearLayout>

            <!-- Verified Brand -->
            <TextView
                android:id="@+id/tv_verified_brand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Official YouTube"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/holo_green_dark"
                android:layout_marginBottom="15dp"
                android:visibility="gone" />

            <!-- Verification Status -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Verification Details"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/darker_gray"
                android:layout_marginBottom="5dp" />

            <TextView
                android:id="@+id/tv_verification_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ Verified Official Domain\n✅ Firebase Database: Not in DB"
                android:textSize="13sp"
                android:layout_marginBottom="20dp"
                android:padding="8dp"
                android:background="@color/lighter_gray" />

            <!-- Reasons -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Analysis Reasons"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/darker_gray"
                android:layout_marginBottom="5dp" />

            <TextView
                android:id="@+id/tv_reasons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No specific reasons - appears safe"
                android:textSize="13sp"
                android:layout_marginBottom="20dp"
                android:padding="8dp"
                android:background="@color/lighter_gray" />

            <!-- Metadata -->
            <TextView
                android:id="@+id/tv_timestamp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scanned: Jan 01, 2024 10:30 AM"
                android:textSize="12sp"
                android:textColor="@color/darker_gray"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_source_app"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Source: WhatsApp"
                android:textSize="12sp"
                android:textColor="@color/darker_gray"
                android:layout_marginBottom="20dp" />

        </LinearLayout>

    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/lighter_gray">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_accept"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="✅ Trust"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:cornerRadius="8dp"
            app:backgroundTint="@android:color/holo_green_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_block"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="🚫 Block"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:cornerRadius="8dp"
            app:backgroundTint="@android:color/holo_red_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="🗑️ Delete"
            android:textSize="12sp"
            app:cornerRadius="8dp"
            app:backgroundTint="@android:color/darker_gray" />

    </LinearLayout>

</LinearLayout>
